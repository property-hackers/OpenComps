  },
  "dependencies": {
    "@electric-sql/pglite": "0.5.4",
    "@electric-sql/pglite-pgtap": "0.0.5",
    "@electric-sql/pglite-postgis": "0.2.4",
    "@electric-sql/pglite-socket": "0.2.7",
    "tinbase": "0.7.1"
  }
