{
  "name": "opencomps",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node scripts/dev_server.mjs",
    "test": "pnpm run test:unit && ./scripts/test_db.sh",
