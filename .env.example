# Copy to .env (gitignored) and fill in real values. `pnpm dev` loads .env automatically.

# Stable JWT secret for tinbase dev keys. Generate with: openssl rand -hex 32
# Without it, tinbase signs API keys with a per-run random secret, so the keys
# printed at startup (Studio login, MCP, curl) stop working after every restart.
TINBASE_JWT_SECRET=replace-with-output-of-openssl-rand-hex-32

# The service_role key printed by `pnpm dev` (valid as long as the secret above
# is unchanged). Referenced by .mcp.json for the Supabase PostgREST MCP server.
SUPABASE_SERVICE_ROLE_KEY=copy-from-pnpm-dev-startup-output
